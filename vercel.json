{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/[...path].ts": {
      "runtime": "@vercel/node@4.0.0",
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  },
  "routes": [
    {
      "src": "^/api/.*",
      "dest": "/api/[...path].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html"
    }
  ]
}